rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /gallery/{document=**} {
      // Anyone can read gallery images (public portfolio)
      allow read: if true;
      // Only authenticated users can create, update, or delete
      allow write: if request.auth.uid == "VEzDSrjBHITxbGpX9zUEHooIIJQ2"
    }
  }
}
