rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /images/{document=**} {
      // Anyone can read images images (public portfolio)
      allow read: if true;
      // Only authenticated users can create, update, or delete
      allow write: if request.auth.uid == "VEzDSrjBHITxbGpX9zUEHooIIJQ2"
    }
    
    match /testImages/{document=**} {
      // Anyone can read images images (public portfolio)
      allow read: if true;
      // Only authenticated users can create, update, or delete
      allow write: if request.auth.uid == "VEzDSrjBHITxbGpX9zUEHooIIJQ2"
    }

    match /users/{document=**} {
      // Needed for admin role lookup during sign in
      allow read: if request.auth != null;
      // Only repository owner can manage admin records
      allow write: if request.auth.uid == "VEzDSrjBHITxbGpX9zUEHooIIJQ2";
    }

    match /testUsers/{document=**} {
      // Needed for admin role lookup during sign in (staging)
      allow read: if request.auth != null;
      // Only repository owner can manage admin records
      allow write: if request.auth.uid == "VEzDSrjBHITxbGpX9zUEHooIIJQ2";
    }
  }
}
