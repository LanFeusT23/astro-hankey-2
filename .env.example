# Image Repository backend: 'stub' | 'firebase' | 'aws'
NUXT_IMAGE_REPOSITORY=stub

# Application environment: 'production' | 'staging'
# When set to 'staging', Firebase uses testImages/ (Firestore) and testGallery/ (Storage)
NUXT_PUBLIC_APP_ENV=production

# Optional comma-separated Firebase Auth user IDs with admin access
# Example: NUXT_PUBLIC_ADMIN_UIDS=uid_1,uid_2
NUXT_PUBLIC_ADMIN_UIDS=

# Base URL for deployment (defaults to / for Firebase Hosting)
NUXT_APP_BASE_URL=/

# Firebase configuration
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
